{
  "name": "classsport",
  "version": "1.0.0",
  "description": "Sistema de Gestión y Reserva de Salones Universitarios",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --reporter=verbose tests/unit",
    "test:integration": "vitest run --reporter=verbose tests/integration",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.1.0",
    "@next/font": "^14.1.0",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/node": "^20.10.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tailwind-merge": "^2.2.0",
    "clsx": "^2.0.0",
    "class-variance-authority": "^0.7.0",
    "zod": "^3.22.4",
    "@hookform/resolvers": "^3.3.4",
    "react-hook-form": "^7.48.0",
    "@tanstack/react-query": "^5.28.0",
    "next-auth": "^5.0.0-beta.13",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.263.1",
    "date-fns": "^2.30.0",
    "@prisma/client": "^5.7.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@types/bcryptjs": "^2.4.2",
    "@tanstack/react-query-devtools": "^5.28.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.1.0",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0",
    "vitest": "^1.1.0",
    "tsconfig-paths": "^4.2.0"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.ts-node.json prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
