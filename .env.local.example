# DEVELOPMENT ENVIRONMENT VARIABLES
# This file is for LOCAL DEVELOPMENT ONLY
# NEVER commit this file to git
# Use .env.example as template and create .env.local on each machine

# Database — Local or development PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/classsport_dev"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/classsport_dev"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-only-secret-key-change-in-production-use-openssl-rand-base64-32"

# Node Environment
NODE_ENV="development"

# Optional: Prisma logging
DEBUG="prisma:*"
